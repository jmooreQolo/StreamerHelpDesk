<Window x:Class="StreamerHelpDeskServer.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Configuration" Height="380" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Network Settings -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Network" FontWeight="Bold" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Host / Bind Address:" VerticalAlignment="Center" Margin="0,0,10,5"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="HostTextBox" VerticalAlignment="Center" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Port Number:" VerticalAlignment="Center" Margin="0,0,10,5"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="PortTextBox" VerticalAlignment="Center" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Hub Path:" VerticalAlignment="Center" Margin="0,0,10,5"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="HubPathTextBox" VerticalAlignment="Center" Margin="0,0,0,5"/>

        <!-- Connection Settings -->
        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Text="Connection" FontWeight="Bold" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Max Connections (0 = unlimited):" VerticalAlignment="Center" Margin="0,0,10,5"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="MaxConnectionsTextBox" VerticalAlignment="Center" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Keep-Alive Interval (sec):" VerticalAlignment="Center" Margin="0,0,10,5"/>
        <TextBox Grid.Row="7" Grid.Column="1" x:Name="KeepAliveTextBox" VerticalAlignment="Center" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Client Timeout (sec):" VerticalAlignment="Center" Margin="0,0,10,5" Grid.RowSpan="2"/>
        <TextBox Grid.Row="8" Grid.Column="1" x:Name="ClientTimeoutTextBox" VerticalAlignment="Center" Margin="0,0,0,5" Grid.RowSpan="2"/>

        <!-- Debugging -->
        <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Text="Debugging" FontWeight="Bold" Margin="0,0,0,5"/>

        <CheckBox Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" x:Name="DetailedErrorsCheckBox" Content="Enable Detailed Errors" Margin="0,0,0,5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="75" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="75" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
